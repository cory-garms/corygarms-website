---
const { type = 'info', title = '' } = Astro.props;

const variants = {
  info: 'bg-primary-900/40 border-primary-500 text-primary-100',
  warning: 'bg-yellow-900/40 border-yellow-500 text-yellow-100',
  danger: 'bg-red-900/40 border-red-500 text-red-100',
  success: 'bg-green-900/40 border-green-500 text-green-100',
  paper: 'bg-surface border-text-muted text-text' // Specifically for academic citations
};
const iconMap = {
  info: 'ℹ️',
  warning: '⚠️',
  danger: '🚨',
  success: '✅',
  paper: '📄'
};
---

<div class={`mt-4 mb-6 px-4 py-3 rounded-md border-l-4 shadow-sm ${variants[type]}`}>
  {title && (
    <div class="font-semibold flex items-center gap-2 mb-1">
      <span>{iconMap[type]}</span>
      <span class="tracking-wide">{title}</span>
    </div>
  )}
  <div class="text-sm opacity-90 leading-relaxed font-sans">
    <slot />
  </div>
</div>
