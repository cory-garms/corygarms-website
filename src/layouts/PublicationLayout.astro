---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    authors: string[];
    journal?: string;
    publishDate: Date | string;
    doi?: string;
    pdfLink?: string;
    abstract: string;
  };
}

const { frontmatter } = Astro.props;

// Helper to format date
const dateStr = frontmatter.publishDate instanceof Date 
    ? frontmatter.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
    : new Date(frontmatter.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---

<Layout title={`${frontmatter.title} | Cory Garms`}>
  <article class="pt-32 pb-24 px-6 md:px-12 max-w-5xl mx-auto">
    
    <a href="/notes" class="text-accent hover:text-accent-300 transition-colors mb-12 inline-block font-mono text-sm group">
        <span class="inline-block transform group-hover:-translate-x-1 transition-transform">&larr;</span> Back to Publications
    </a>

    <header class="mb-16 border-b border-primary-800/50 pb-12 reveal">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight font-serif tracking-tight">
        {frontmatter.title}
      </h1>
      
      <div class="text-lg md:text-xl text-primary-200 mb-4 font-medium">
        {frontmatter.authors.join(', ')}
      </div>
      
      <div class="flex flex-col md:flex-row gap-4 md:items-center text-text-muted font-mono text-sm mb-8">
        {frontmatter.journal && <span class="font-semibold text-white">{frontmatter.journal}</span>}
        <span class="hidden md:inline text-primary-800">&bull;</span>
        <time>{dateStr}</time>
        {frontmatter.doi && (
            <>
              <span class="hidden md:inline text-primary-800">&bull;</span>
              <a href={`https://doi.org/${frontmatter.doi}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
                DOI: {frontmatter.doi}
              </a>
            </>
        )}
      </div>

      <div class="flex gap-4">
        {frontmatter.pdfLink && (
            <a href={frontmatter.pdfLink} target="_blank" rel="noopener noreferrer" class="px-6 py-2 bg-primary-700 hover:bg-primary-600 text-white rounded-md text-sm font-medium transition-colors border border-primary-500 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                View PDF
            </a>
        )}
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Abstract Sidebar or Full width depending on slot content -->
      <div class="md:col-span-4 lg:col-span-3 reveal reveal-left" style="transition-delay: 200ms;">
        <h3 class="text-xl font-bold text-white mb-4 border-b border-primary-800/50 pb-2">Abstract</h3>
        <p class="text-sm text-text-muted leading-relaxed font-mono">
            {frontmatter.abstract}
        </p>
      </div>

      <!-- Main Content Area -->
      <div class="md:col-span-8 lg:col-span-9 prose prose-invert prose-primary max-w-none prose-img:rounded-xl prose-img:shadow-2xl prose-headings:text-white prose-a:text-accent hover:prose-a:text-accent-300 reveal reveal-right" style="transition-delay: 300ms;">
        <slot />
      </div>
    </div>
  </article>
</Layout>
