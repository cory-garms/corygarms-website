---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const notesEntries = await getCollection('notes');
  return notesEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Cory Garms`}>
  <main class="pt-32 pb-16 px-6 sm:px-12 md:px-24">
    <div class="max-w-3xl mx-auto">
        <a href="/" class="text-accent hover:text-accent-300 transition-colors mb-8 inline-block font-mono text-sm">
            &larr; Back to Home
        </a>
        
        <header class="mb-12">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
                {entry.data.title}
            </h1>
            <div class="flex items-center gap-4 text-text-muted font-mono text-sm">
                <time datetime={entry.data.publishDate.toISOString()}>
                    {entry.data.publishDate.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                    })}
                </time>
                <div class="flex gap-2">
                    {entry.data.tags.map((tag) => (
                        <span class="px-2 py-1 bg-primary-900/40 border border-primary-800 rounded-md text-primary-300">
                            #{tag}
                        </span>
                    ))}
                </div>
            </div>
        </header>

        <article class="prose prose-invert prose-primary max-w-none">
            <Content />
        </article>
    </div>
  </main>
</Layout>
