---
import Layout from "../layouts/Layout.astro";
import PointCloudHero from "../components/PointCloudHero.jsx";
import PortfolioGrid from "../components/PortfolioGrid.astro";
import NotesList from "../components/NotesList.astro";
import ContactSection from "../components/ContactSection.astro";
---

<Layout title="Home">
  <section
    id="hero"
    class="relative w-full h-[80vh] min-h-[600px] flex items-center overflow-hidden"
  >
    <!-- 3D Background -->
    <div class="absolute inset-0 z-0">
      <PointCloudHero client:load />
    </div>

    <!-- Overlay Content -->
    <div
      class="relative z-10 max-w-7xl mx-auto px-6 w-full pointer-events-none"
    >
      <div
        id="hero-card"
        class="max-w-3xl pointer-events-auto bg-background/60 p-8 rounded-2xl backdrop-blur-sm border border-primary-800/30 transition-all duration-300 relative overflow-hidden group"
      >
        <button
          id="minimize-btn"
          class="absolute top-4 right-4 p-2 text-text-muted hover:text-white rounded-lg hover:bg-primary-900/50 transition-colors z-20 cursor-pointer"
          aria-label="Toggle Intro"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 transition-transform duration-300"
            id="minimize-icon"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <div
          id="hero-content"
          class="transition-all duration-500 opacity-100 max-h-[1000px]"
        >
          <h1
            class="text-5xl md:text-6xl font-sans font-bold text-white tracking-tight mb-4"
          >
            Exploring the World in <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-primary-400"
              >3D</span
            >
          </h1>
          <h2
            class="text-xl md:text-2xl text-text-muted font-light mb-8 font-mono"
          >
            Remote Sensing | Lidar | Computer Vision
          </h2>
          <p class="text-lg text-text-main/90 mb-10 max-w-2xl leading-relaxed">
            I am a Senior Scientist specializing in hyperspectral imaging and 3D
            point cloud processing, currently focused on agricultural and
            forestry reconstruction for the USDA STTR program.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="#portfolio"
              class="px-8 py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(139,43,136,0.3)] hover:shadow-[0_0_25px_rgba(139,43,136,0.5)]"
            >
              View Projects
            </a>
            <a
              href="#contact"
              class="px-8 py-3 bg-surface border border-primary-600/50 hover:border-primary-500 text-white font-medium rounded-lg transition-all duration-300"
            >
              Get in Touch
            </a>
          </div>
        </div>
        <div
          id="hero-minimized-title"
          class="absolute top-4 left-6 font-mono text-sm text-primary-300 opacity-0 pointer-events-none transition-opacity duration-300"
        >
          Exploring the World in 3D...
        </div>
      </div>
    </div>

    <!-- Gradient Overlay at bottom for smooth transition -->
    <div
      class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-background to-transparent pointer-events-none z-10"
    >
    </div>
  </section>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const btn = document.getElementById("minimize-btn");
      const icon = document.getElementById("minimize-icon");
      const content = document.getElementById("hero-content");
      const card = document.getElementById("hero-card");
      const title = document.getElementById("hero-minimized-title");
      let isMin = false;

      if (btn && content && card) {
        btn.addEventListener("click", () => {
          isMin = !isMin;
          if (isMin) {
            content.style.maxHeight = "0px";
            content.style.opacity = "0";
            content.style.visibility = "hidden";
            card.classList.remove("p-8");
            card.classList.add("p-3", "h-14");
            icon.style.transform = "rotate(180deg)";
            title.style.opacity = "1";
          } else {
            content.style.visibility = "visible";
            content.style.maxHeight = "1000px";
            content.style.opacity = "1";
            card.classList.add("p-8");
            card.classList.remove("p-3", "h-14");
            icon.style.transform = "rotate(0deg)";
            title.style.opacity = "0";
          }
        });
      }
    });
  </script>

  <section id="about" class="py-24 bg-background overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        <!-- Images Side -->
        <div class="w-full lg:w-1/3 flex flex-col gap-6 reveal reveal-left">
          <div
            class="aspect-square w-full bg-surface rounded-2xl border border-primary-800/30 overflow-hidden relative shadow-xl flex items-center justify-center group"
          >
            <div
              class="absolute inset-0 bg-gradient-to-tr from-primary-900/20 to-transparent z-10 pointer-events-none"
            >
            </div>
            <img
              src="/images/profile.jpg"
              alt="Cory Garms"
              class="w-full h-full object-cover relative z-0 group-hover:scale-105 transition-transform duration-700"
            />
          </div>

          <!-- Family Image -->
          <div
            class="aspect-video w-full bg-surface/50 rounded-xl border border-primary-800/30 overflow-hidden relative shadow flex items-center justify-center group"
          >
            <img
              src="/images/amanda.jpg"
              alt="Cory and Amanda Garms"
              class="w-full h-full object-cover relative z-0 opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
            />
          </div>
        </div>

        <!-- Text Side -->
        <div
          class="w-full lg:w-2/3 reveal reveal-right"
          style="transition-delay: 200ms;"
        >
          <h3
            class="text-3xl font-bold mb-8 text-white inline-block border-b-2 border-accent pb-2"
          >
            About Me
          </h3>

          <div
            class="prose prose-invert prose-primary max-w-none font-mono text-sm leading-relaxed mb-8"
          >
            <p>
              Hi, I'm Cory. I'm a Senior Scientist specializing in applied
              remote sensing, natural resource monitoring, and hardware/software
              integration. I currently work at Spectral Sciences, Inc. in
              Burlington, MA, where I collaborate with brilliant people to build
              awesome stuff!
            </p>
            <p>
              My approach is characterized by a "Servant Leadership" philosophy,
              prioritizing clean, container-ready Python and modular
              architectures.
            </p>
            <p>
              Beyond the code and the clouds, I enjoy fishing, kayaking, hiking,
              cooking, and supporting the Red Sox, Spurs, and LSU Tigers. I am
              also an avid photographer; you can <a
                href="https://photos.app.goo.gl/7yoaVpVCb5m7QZxs6"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:text-accent-300 underline underline-offset-4 transition-colors"
                >view my flower photography album here</a
              > and <a href="/reading-list" class="text-accent hover:text-accent-300 underline underline-offset-4 transition-colors">view my reading list here</a>.
            </p>
            <p>
              My scientific research and publications can be found on my <a
                href="https://scholar.google.com/citations?user=pL1DI_AAAAAJ&hl=en"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:text-accent-300 underline underline-offset-4 transition-colors"
                >Google Scholar profile</a
              >.
            </p>
            <p>
              I'm a proud member and Chaplain of the Medford Malden Elks Lodge
              #915.
            </p>
            <p
              class="mb-8 leading-relaxed border-l-4 border-accent pl-6 py-2 bg-surface/30 rounded-r-lg"
            >
              Above all, my greatest joy is my family. I am incredibly grateful
              for the love and unwavering support of my beautiful wife, Amanda.
              We celebrated our 5-year wedding anniversary in August 2025, and
              she makes all of these adventures—both technical and
              outdoors—possible.
            </p>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
            <div
              class="bg-surface p-6 rounded-xl border border-primary-800/30 shadow-sm group hover:border-accent/50 transition-colors reveal"
              style="transition-delay: 300ms;"
            >
              <div class="text-accent text-2xl font-mono font-bold mb-2">
                01
              </div>
              <h4 class="text-white font-semibold text-sm">Data Pipelines</h4>
            </div>
            <div
              class="bg-surface p-6 rounded-xl border border-primary-800/30 shadow-sm group hover:border-accent/50 transition-colors reveal"
              style="transition-delay: 400ms;"
            >
              <div class="text-accent text-2xl font-mono font-bold mb-2">
                02
              </div>
              <h4 class="text-white font-semibold text-sm">3D Vision</h4>
            </div>
            <div
              class="bg-surface p-6 rounded-xl border border-primary-800/30 shadow-sm group hover:border-accent/50 transition-colors reveal"
              style="transition-delay: 500ms;"
            >
              <div class="text-accent text-2xl font-mono font-bold mb-2">
                03
              </div>
              <h4 class="text-white font-semibold text-sm">DevOps</h4>
            </div>
            <div
              class="bg-surface p-6 rounded-xl border border-primary-800/30 shadow-sm group hover:border-accent/50 transition-colors reveal"
              style="transition-delay: 600ms;"
            >
              <div class="text-accent text-2xl font-mono font-bold mb-2">
                04
              </div>
              <h4 class="text-white font-semibold text-sm">Community</h4>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PortfolioGrid />
  <NotesList />
  <ContactSection />
</Layout>
